{
  "name": "oc-mirror-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:plugin": "webpack --config webpack.plugin.js --mode production",
    "build": "npm run build:plugin",
    "start:plugin": "webpack serve --config webpack.plugin.js --mode development",
    "dev": "webpack serve --config webpack.dev.js",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest"
  },
  "consolePlugin": {
    "name": "oc-mirror-operator",
    "version": "0.1.0",
    "displayName": "OC Mirror",
    "description": "Manage OC Mirror Operator ImageSets and MirrorTargets from the OpenShift Console",
    "exposedModules": {
      "MirrorTargetListPage": "./plugin/pages/MirrorTargetListPage",
      "MirrorTargetDetailPage": "./plugin/pages/MirrorTargetDetailPage",
      "FailedImagesPage": "./plugin/pages/FailedImagesPage",
      "FailedImagesAllPage": "./plugin/pages/FailedImagesAllPage",
      "CatalogBrowserPage": "./plugin/pages/CatalogBrowserPage",
      "ImageSetListPage": "./plugin/pages/ImageSetListPage",
      "ImageSetDetailPage": "./plugin/pages/ImageSetDetailPage"
    },
    "dependencies": {
      "@console/pluginAPI": ">=4.19.0-0"
    }
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.22-latest",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.22-latest",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "@swc/core": "^1.15.40",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.9.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "mini-css-extract-plugin": "^2.9.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.18.1",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  }
}
